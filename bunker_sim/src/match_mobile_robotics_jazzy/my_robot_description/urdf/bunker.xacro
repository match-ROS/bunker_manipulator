  <!-- /////////////////////////////////   gazebo color   ////////////////////////////////////// -->

  <!-- Minimal ros2_control configuration for Gazebo (gz/ignition)
       This exposes velocity command & state interfaces for the four drive joints
       so gz_ros2_control / ign_ros2_control can attach a hardware bridge. -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="wheel1_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel2_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel3_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel4_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- New joints for additional track wheels -->
    <joint name="wheel1.2_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel3.1_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel3.2_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel4.1_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel4.2_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wheel2.2_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo Sim integration: load gz/ign ros2_control bridge plugin -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
  <!-- Use a unique controller manager node name so we can target parameters reliably -->
  <controller_manager_name>controller_manager_node</controller_manager_name>
      <!-- Ensure controller_manager is created in the root namespace -->
      <ros>
        <namespace>/</namespace>
      </ros>
  <!-- Controller configs/types (loaded as plugin params file) -->
  <parameters>$(arg controllers_yaml)</parameters>
    </plugin>
  </gazebo>

  <!-- Gazebo physics tuning: ensure wheel collisions have enough friction so
       wheel rotation turns into traction (otherwise the wheels can spin in place).
       Adjust mu1/mu2 if it still slips. -->
  <gazebo reference="wheel1_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel2_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel3_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel4_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <!-- Friction parameters for additional track wheels -->
  <gazebo reference="wheel1.2_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel3.1_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel3.2_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel4.1_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel4.2_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="wheel2.2_Link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>

</robot>
